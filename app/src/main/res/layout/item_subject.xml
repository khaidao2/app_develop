<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Thông tin môn học -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_subject_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Kinh tế vi mô" />

            <TextView
                android:id="@+id/txt_subject_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/order_gray"
                android:textSize="12sp"
                tools:text="Mã môn: BEE1037" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txt_subject_credits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/order_blue"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="3 tín chỉ" />

                <TextView
                    android:id="@+id/txt_subject_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@color/status_completed_bg"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textColor="@color/status_completed_txt"
                    android:textSize="11sp"
                    tools:text="Bắt buộc" />
            </LinearLayout>
        </LinearLayout>

        <!-- Huy hiệu khoảng cách Euclid -->
        <LinearLayout
            android:id="@+id/layout_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@color/status_logistics_bg"
            android:gravity="center"
            android:minWidth="56dp"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/txt_distance_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/status_logistics_txt"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="1.41" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_subject_distance_label"
                android:textColor="@color/status_logistics_txt"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
