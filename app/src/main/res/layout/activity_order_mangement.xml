<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F8F9FA"
    tools:context=".OrderMangementActivity">    <!-- Tiêu đề Order Management -->
    <TextView
        android:id="@+id/txt_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/str_order_management_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#212529"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"/>

    <!-- TableLayout 2 dòng 3 cột -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="1"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <!-- Dòng 1: From Date -->
        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_from_date"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#495057"
                android:layout_marginEnd="12dp"/>

            <EditText
                android:id="@+id/edt_from_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/str_date_hint"
                android:textSize="16sp"
                android:focusable="false"
                android:clickable="true"
                android:textColor="#212529"
                android:background="@android:drawable/editbox_background_normal"
                android:padding="8dp"/>

            <ImageView
                android:id="@+id/img_from_date"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@mipmap/ic_date"
                android:contentDescription="@string/str_desc_select_from_date"
                android:layout_marginStart="8dp"
                android:padding="4dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>
        </TableRow>

        <!-- Dòng 2: To Date -->
        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_to_date"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#495057"
                android:layout_marginEnd="12dp"/>

            <EditText
                android:id="@+id/edt_to_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/str_date_hint"
                android:textSize="16sp"
                android:focusable="false"
                android:clickable="true"
                android:textColor="#212529"
                android:background="@android:drawable/editbox_background_normal"
                android:padding="8dp"/>

            <ImageView
                android:id="@+id/img_to_date"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@mipmap/ic_date"
                android:contentDescription="@string/str_desc_select_to_date"
                android:layout_marginStart="8dp"
                android:padding="4dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>
        </TableRow>
    </TableLayout>

    <!-- Khu vực 2 ImageView: Filter và Clear Filter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/img_filter"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@mipmap/ic_filterfilter"
            android:contentDescription="@string/str_desc_filter"
            android:layout_marginEnd="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"/>

        <ImageView
            android:id="@+id/img_clear_filter"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@mipmap/ic_clear_filter"
            android:contentDescription="@string/str_desc_clear_filter"
            android:layout_marginStart="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- ListView kết quả đã lọc -->
    <ListView
        android:id="@+id/lv_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:divider="#E9ECEF"
        android:dividerHeight="1dp"
        android:elevation="2dp"
        android:padding="8dp"/>
</LinearLayout>