<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".MainThreadObjectActivity">

    <!-- Title -->
    <TextView
        android:id="@+id/txt_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/str_main_thread_object_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#3F51B5"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Mocked text view from step 1 -->
    <TextView
        android:id="@+id/txt_number_of_products"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/str_number_of_products"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#E91E63"
        android:padding="10dp"
        android:background="#F0F0F0"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- Number of products input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str_num_products_label"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/edt_num_products"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:inputType="number"
            android:hint="@string/str_hint_number"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Download Control Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_download"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/str_download"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/txt_download_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#3F51B5"
            android:padding="8dp" />
    </LinearLayout>

    <!-- ListView for downloaded products -->
    <ListView
        android:id="@+id/lv_downloaded_products"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp"
        android:background="#FAFAFA"
        android:padding="4dp"
        android:listSelector="#403F51B5"
        android:drawSelectorOnTop="true"
        android:layout_marginBottom="16dp" />

    <!-- Exit button -->
    <Button
        android:id="@+id/btn_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/str_exit" />
</LinearLayout>
